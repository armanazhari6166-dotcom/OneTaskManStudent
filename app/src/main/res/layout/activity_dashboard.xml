<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    tools:context=".DashboardActivity">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="15dp"
        android:background="#1E1E1E">

        <TextView
            android:id="@+id/tv_header_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Hi, Arman"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_rank_streak"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏅 Civilian | 🔥 0-Day Streak"
            android:textColor="#4CAF50"
            android:textSize="9sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_unverified"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠️ UNVERIFIED"
            android:textColor="#FFC107"
            android:textSize="8sp"
            android:textStyle="bold"
            android:layout_marginStart="5dp"/>

        <Button
            android:id="@+id/btn_logout"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:layout_marginStart="10dp"
            android:backgroundTint="#F44336"
            android:text="LOGOUT"
            android:textColor="@android:color/white"
            android:textSize="8sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/toggle_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/header"
        android:padding="10dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_pending"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="PENDING"/>

        <Button
            android:id="@+id/btn_history"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="HISTORY"/>

    </LinearLayout>

    <TextView
        android:id="@+id/lbl_xp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/toggle_bar"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="20dp"
        android:text="XP: ..."
        android:textColor="@android:color/white"/>


    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_tasks"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/lbl_xp"
        android:layout_above="@+id/nav_bar" />

    <LinearLayout
        android:id="@+id/nav_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#181818"
        android:padding="10dp">

        <Button
            android:id="@+id/btn_tasks_nav"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📝 TASKS"/>

        <Button
            android:id="@+id/btn_classes_nav"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🏫 CLASSES"/>

    </LinearLayout>

</RelativeLayout>